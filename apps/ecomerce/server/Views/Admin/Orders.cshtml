@model IEnumerable<EcomServer.Models.Order>
@{
    ViewData["Title"] = "Orders";
}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">Orders</h1>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Id</th>
                            <th>Date</th>
                            <th>User</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr>
                                <td class="ps-4">#@item.Id</td>
                                <td>@item.OrderDate.ToString("g")</td>
                                <td class="fw-semibold">@(item.User?.Username ?? "Unknown")</td>
                                <td><span class="badge bg-primary rounded-pill">Processing</span></td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-outline-secondary">View Details</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>