@model IEnumerable<Uis.Server.Models.Order>

@{
    ViewData["Title"] = "إدارة الطلبات";
}

<div class="mb-8">
    <h3 class="text-xl font-bold text-gray-800 underline decoration-indigo-500 decoration-4 underline-offset-8">متابعة طلبات العملاء</h3>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-right">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100 text-gray-500 font-bold text-xs uppercase tracking-tighter">
                    <th class="p-4">الرقم</th>
                    <th class="p-4">الخدمة</th>
                    <th class="p-4">الطالب</th>
                    <th class="p-4 text-center">الحالة الحالية</th>
                    <th class="p-4">المبلغ</th>
                    <th class="p-4 text-center">تحديث الحالة</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-sm">
                @foreach (var order in Model)
                {
                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="p-4 font-mono text-xs text-gray-400">#@order.Id.ToString().Substring(0,8)</td>
                        <td class="p-4 font-bold text-gray-800">@(order.Service?.Title ?? "خدمة محذوفة")</td>
                        <td class="p-4 text-gray-600 font-medium">@(order.Student?.FullName ?? "مستخدم محذوف")</td>
                        <td class="p-4 text-center">
                            <span class="px-3 py-1 rounded-full text-xs font-black border
                                @(order.Status == "Pending" ? "bg-orange-50 text-orange-700 border-orange-200" : 
                                  order.Status == "In Progress" ? "bg-blue-50 text-blue-700 border-blue-200" : 
                                  order.Status == "Completed" ? "bg-green-50 text-green-700 border-green-200" : "bg-red-50 text-red-700 border-red-200")">
                                @(order.Status == "Pending" ? "قيد الانتظار" : 
                                  order.Status == "In Progress" ? "قيد التنفيذ" : 
                                  order.Status == "Completed" ? "مكتمل" : "ملغي")
                            </span>
                        </td>
                        <td class="p-4 font-extrabold text-indigo-600">@order.Price.ToString("N0") ج.م</td>
                        <td class="p-4">
                            <a asp-action="OrderDetails" asp-route-id="@order.Id" class="inline-block bg-indigo-50 text-indigo-600 hover:bg-indigo-600 hover:text-white border border-indigo-200 px-4 py-1.5 rounded-lg text-xs font-bold transition-all shadow-sm">
                                <i class="fas fa-eye ml-1"></i> التفاصيل
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
