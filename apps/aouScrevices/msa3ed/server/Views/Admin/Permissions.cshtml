@model IEnumerable<Uis.Server.Models.Permission>

@{
    ViewData["Title"] = "تعريف صلاحيات النظام";
    var groupedPermissions = Model.GroupBy(p => p.Group).OrderBy(g => g.Key);
}

<div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center space-y-4 md:space-y-0">
    <div>
        <h3 class="text-2xl font-black text-gray-800 flex items-center">
            <i class="fas fa-shield-alt ml-3 text-indigo-600"></i> القاموس المرجعي للصلاحيات
        </h3>
        <p class="text-sm text-gray-400 mt-1 font-medium">إدارة وتدقيق كافة المفاتيح البرمجية المستخدمة في نظام التصاريح.</p>
    </div>
    <div class="flex space-x-3 rtl:space-x-reverse">
        <div class="bg-indigo-600 text-white px-5 py-2 rounded-2xl shadow-lg shadow-indigo-200 text-center">
            <p class="text-[10px] uppercase font-bold opacity-70">إجمالي الصلاحيات</p>
            <p class="text-xl font-black">@Model.Count()</p>
        </div>
        <div class="bg-white border border-gray-100 px-5 py-2 rounded-2xl shadow-sm text-center">
            <p class="text-[10px] uppercase font-bold text-gray-400">عدد المجموعات</p>
            <p class="text-xl font-black text-gray-700">@groupedPermissions.Count()</p>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
    <!-- Sidebar: Add New -->
    <div class="lg:col-span-4">
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 sticky top-6">
            <h3 class="text-lg font-black text-gray-800 mb-6 flex items-center">
                <i class="fas fa-plus-circle ml-2 text-indigo-500"></i> تسجيل صلاحية برمجية
            </h3>
            <form asp-action="CreatePermission" method="post" class="space-y-5">
                <div>
                    <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2">الاسم التقني (Unique Name)</label>
                    <input type="text" name="name" required 
                           class="w-full px-4 py-3 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all bg-gray-50 font-mono text-sm"
                           placeholder="مثال: Users.UpdateStatus">
                </div>
                <div>
                    <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2">المجموعة الوظيفية</label>
                    <div class="relative">
                        <i class="fas fa-layer-group absolute left-4 top-1/2 -translate-y-1/2 text-gray-300"></i>
                        <input type="text" name="group" required 
                               class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all bg-gray-50 text-sm font-bold"
                               placeholder="Management, Finance, etc.">
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2">شرح الغرض من الصلاحية</label>
                    <textarea name="description" rows="3"
                           class="w-full px-4 py-3 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all bg-gray-50 text-sm leading-relaxed"
                           placeholder="ما هي الوظائف التي سيتمكن صاحب هذا المفتاح من تنفيذها؟"></textarea>
                </div>
                <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-black py-4 rounded-2xl transition-all shadow-xl hover:scale-[1.02] active:scale-95">
                    إعتماد الصلاحية
                </button>
            </form>
            
            <div class="mt-8 p-4 bg-amber-50 rounded-2xl border border-amber-100">
                <p class="text-[10px] text-amber-700 font-medium leading-relaxed italic">
                    <i class="fas fa-info-circle ml-1"></i> ملاحظة: الأسماء التقنية تُستخدم داخل الكود البرمجي للتحقق من الوصول. لا تقم بتغيير الأسماء الموجودة حالياً لتجنب توقف ميزات النظام.
                </p>
            </div>
        </div>
    </div>

    <!-- Main Content: List -->
    <div class="lg:col-span-8">
        <!-- Search Bar -->
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-4 mb-6 flex items-center">
            <div class="relative flex-1">
                <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-300"></i>
                <input type="text" id="permSearch" onkeyup="filterPermissions()" 
                       class="w-full pl-12 pr-4 py-3 bg-transparent outline-none text-sm font-bold text-gray-700" 
                       placeholder="ابحث في مئات الصلاحيات المتاحة (بالاسم أو الوصف)...">
            </div>
        </div>

        <div id="permissionsContainer">
            @foreach (var group in groupedPermissions)
            {
                <section class="group-section mb-10" data-group="@group.Key">
                    <div class="flex items-center mb-6">
                        <div class="w-8 h-8 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center text-xs font-black shadow-sm ml-3">
                            @group.Count()
                        </div>
                        <h4 class="text-md font-black text-gray-800 uppercase tracking-wider">مجموعة @(group.Key ?? "عام")</h4>
                        <div class="flex-1 h-px bg-gray-100 mr-4"></div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        @foreach (var p in group)
                        {
                            <div class="perm-card bg-white rounded-2xl p-5 border border-gray-100 shadow-sm hover:border-indigo-400 hover:shadow-indigo-50 transition-all group" 
                                 data-name="@p.Name.ToLower()" data-desc="@p.Description?.ToLower()">
                                <div class="flex justify-between items-start mb-4">
                                    <code class="bg-indigo-50 text-indigo-600 px-3 py-1 rounded-lg text-[11px] font-black border border-indigo-100">@p.Name</code>
                                    <form asp-action="DeletePermission" asp-route-id="@p.Id" method="post" onsubmit="return confirm('هل أنت متأكد؟')">
                                        <button type="submit" class="text-gray-200 hover:text-red-500 transition-colors p-1"><i class="fas fa-trash-alt text-xs"></i></button>
                                    </form>
                                </div>
                                <h5 class="text-xs font-bold text-gray-800 mb-1 group-hover:text-indigo-700">@p.Name.Split('.').Last() Access</h5>
                                <p class="text-[10px] text-gray-400 font-medium leading-relaxed">@(p.Description ?? "لا يوجد وصف لهذه الصلاحية.")</p>
                            </div>
                        }
                    </div>
                </section>
            }
        </div>
        
        <!-- Empty State -->
        <div id="noResults" class="hidden py-20 text-center">
            <i class="fas fa-search text-6xl text-gray-100 mb-4"></i>
            <p class="text-gray-400 font-bold">عذراً، لم نجد أي صلاحية تطابق بحثك.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterPermissions() {
            const input = document.getElementById('permSearch');
            const filter = input.value.toLowerCase();
            const cards = document.getElementsByClassName('perm-card');
            const sections = document.getElementsByClassName('group-section');
            let overallFound = false;

            for (let i = 0; i < cards.Length || i < cards.length; i++) {
                const card = cards[i];
                const name = card.getAttribute('data-name');
                const desc = card.getAttribute('data-desc');

                if (name.includes(filter) || desc.includes(filter)) {
                    card.classList.remove('hidden');
                    overallFound = true;
                } else {
                    card.classList.add('hidden');
                }
            }

            // Hide empty sections
            for (let s of sections) {
                const visibleCards = s.querySelectorAll('.perm-card:not(.hidden)');
                if (visibleCards.length === 0) {
                    s.classList.add('hidden');
                } else {
                    s.classList.remove('hidden');
                }
            }

            // Show empty state
            document.getElementById('noResults').classList.toggle('hidden', overallFound);
        }
    </script>
}
