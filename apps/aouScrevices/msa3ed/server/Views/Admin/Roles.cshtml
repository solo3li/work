@model IEnumerable<Uis.Server.Models.Role>

@{
    ViewData["Title"] = "إدارة الأدوار والصلاحيات";
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Add Role Form -->
    <div class="lg:col-span-1">
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 sticky top-6">
            <h3 class="text-xl font-black text-gray-800 mb-6 flex items-center">
                <i class="fas fa-user-shield ml-2 text-indigo-500"></i> إضافة دور جديد
            </h3>
            <form asp-action="CreateRole" method="post" class="space-y-6">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">اسم الدور</label>
                    <input type="text" name="name" required 
                           class="w-full px-4 py-3 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all bg-gray-50 font-bold"
                           placeholder="مثال: مراجع، مشرف...">
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">الوصف</label>
                    <textarea name="description" rows="3"
                           class="w-full px-4 py-3 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all bg-gray-50 text-sm"
                           placeholder="اشرح صلاحيات هذا الدور..."></textarea>
                </div>
                <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-black py-4 rounded-2xl transition-all shadow-lg hover:scale-[1.02] active:scale-95">
                    <i class="fas fa-plus-circle ml-2"></i>إنشاء الدور
                </button>
            </form>
        </div>
    </div>

    <!-- Roles List -->
    <div class="lg:col-span-2">
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-6 border-b border-gray-100 flex flex-col md:flex-row justify-between items-center bg-gray-50/50 gap-4">
                <h3 class="text-lg font-bold text-gray-800">الأدوار الحالية</h3>
                
                <form method="get" class="flex items-center gap-2">
                    <div class="relative">
                        <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        <input type="text" name="search" value="@ViewBag.Search" placeholder="بحث..." 
                               class="pl-10 pr-4 py-2 border border-gray-200 rounded-xl text-xs focus:ring-2 focus:ring-indigo-500 outline-none">
                    </div>
                    <select name="isSystem" class="px-4 py-2 border border-gray-200 rounded-xl text-xs focus:ring-2 focus:ring-indigo-500 outline-none bg-white font-bold">
                        <option value="">كل الأنواع</option>
                        <option value="true" selected="@(ViewBag.IsSystem == true)">نظامي</option>
                        <option value="false" selected="@(ViewBag.IsSystem == false)">مخصص</option>
                    </select>
                    <button type="submit" class="bg-gray-800 text-white p-2 rounded-xl hover:bg-black transition-all">
                        <i class="fas fa-filter"></i>
                    </button>
                </form>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-right">
                    <thead>
                        <tr class="bg-gray-50 border-b border-gray-100 text-gray-400 font-bold text-[10px] uppercase tracking-widest">
                            <th class="p-4">اسم الدور</th>
                            <th class="p-4">الوصف</th>
                            <th class="p-4 text-center">النوع</th>
                            <th class="p-4 text-center">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 text-sm">
                        @foreach (var role in Model)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="p-4">
                                    <span class="font-black text-indigo-600 px-3 py-1 bg-indigo-50 rounded-lg border border-indigo-100 uppercase tracking-tighter">
                                        @role.Name
                                    </span>
                                </td>
                                <td class="p-4 text-xs text-gray-500 max-w-xs">
                                    @(role.Description ?? "لا يوجد وصف")
                                </td>
                                <td class="p-4 text-center">
                                    @if(role.IsSystemRole)
                                    {
                                        <span class="text-[10px] font-bold text-amber-600 bg-amber-50 px-2 py-0.5 rounded border border-amber-100"><i class="fas fa-lock ml-1"></i>نظامي</span>
                                    }
                                    else
                                    {
                                        <span class="text-[10px] font-bold text-gray-400 bg-gray-50 px-2 py-0.5 rounded border border-gray-200">مخصص</span>
                                    }
                                </td>
                                <td class="p-4">
                                    <div class="flex justify-center space-x-2 rtl:space-x-reverse">
                                        <a asp-action="EditRole" asp-route-id="@role.Id" class="text-blue-500 hover:bg-blue-50 p-2 rounded-xl transition-all" title="تعديل">
                                            <i class="fas fa-edit"></i>
                                        </a>

                                        <a asp-action="RolePermissions" asp-route-id="@role.Id" class="text-indigo-600 hover:bg-indigo-50 px-3 py-1 rounded-xl text-[10px] font-black border border-indigo-200 transition-all flex items-center">
                                            <i class="fas fa-key ml-1"></i> الصلاحيات
                                        </a>

                                        @if(!role.IsSystemRole)
                                        {
                                            <form asp-action="DeleteRole" asp-route-id="@role.Id" method="post" onsubmit="return confirm('حذف الدور قد يؤثر على المستخدمين المرتبطين به. هل أنت متأكد؟')">
                                                <button type="submit" class="text-red-400 hover:text-red-600 p-2 hover:bg-red-50 rounded-xl transition-all">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <div class="p-2 opacity-20"><i class="fas fa-shield-alt text-gray-400"></i></div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-8 bg-amber-50 border border-amber-100 rounded-2xl p-6 flex items-start">
             <i class="fas fa-info-circle text-amber-500 mt-1 ml-3"></i>
             <p class="text-xs text-amber-800 leading-relaxed font-medium">
                أدوار النظام (Admin, Student, Executor) هي أدوار جوهرية لعمل المنصة. لا يمكنك تعديل أسمائها أو حذفها، بينما يمكنك التحكم الكامل في الأدوار الإضافية التي تنشئها.
             </p>
        </div>
    </div>
</div>
