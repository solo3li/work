@model IEnumerable<Uis.Server.Models.User>

@{
    ViewData["Title"] = "إدارة المستخدمين";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-6 border-b border-gray-100 flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <h3 class="text-xl font-bold text-gray-800">قائمة الأعضاء</h3>
        
        <div class="flex gap-2">
            <a asp-action="CreateUser" class="bg-green-600 text-white px-4 py-2 rounded-xl font-bold hover:bg-green-700 transition-all shadow-md text-sm">
                <i class="fas fa-plus ml-1"></i> إضافة مستخدم
            </a>
        </div>
    </div>

    <div class="p-4 bg-gray-50 border-b border-gray-100">
        <!-- Search & Filter Form -->
        <form method="get" class="flex flex-wrap items-center gap-3 rtl:space-x-reverse">
            <div class="relative">
                <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                <input type="text" name="search" value="@ViewBag.Search" placeholder="بحث بالاسم أو الإيميل..." 
                       class="pl-10 pr-4 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 outline-none min-w-[200px]">
            </div>
            <select name="role" class="px-4 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 outline-none bg-white font-bold">
                <option value="">كل الأدوار</option>
                <option value="Student" selected="@(ViewBag.Role == "Student")">طلاب</option>
                <option value="Executor" selected="@(ViewBag.Role == "Executor")">منفذين</option>
                <option value="Admin" selected="@(ViewBag.Role == "Admin")">مدراء</option>
            </select>
            <select name="isActive" class="px-4 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 outline-none bg-white font-bold">
                <option value="">كل الحالات</option>
                <option value="true" selected="@(ViewBag.IsActive == true)">نشط</option>
                <option value="false" selected="@(ViewBag.IsActive == false)">محظور</option>
            </select>
            <div class="flex items-center gap-2">
                <label class="text-xs font-bold text-gray-500">من:</label>
                <input type="date" name="startDate" value="@ViewBag.StartDate" class="px-3 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
            </div>
            <div class="flex items-center gap-2">
                <label class="text-xs font-bold text-gray-500">إلى:</label>
                <input type="date" name="endDate" value="@ViewBag.EndDate" class="px-3 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
            </div>
            <button type="submit" class="bg-indigo-600 text-white px-6 py-2 rounded-xl font-bold hover:bg-indigo-700 transition-all shadow-md">تصفية</button>
            @if(!string.IsNullOrEmpty(ViewBag.Search) || !string.IsNullOrEmpty(ViewBag.Role) || ViewBag.IsActive != null || !string.IsNullOrEmpty(ViewBag.StartDate))
            {
                <a href="/Admin/Users" class="text-red-500 text-sm font-bold hover:underline">إلغاء</a>
            }
        </form>
    </div>
    
    <div class="overflow-x-auto">
        <table class="w-full text-right">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100 text-gray-500 font-bold text-xs">
                    <th class="p-4">الاسم الكامل</th>
                    <th class="p-4">البريد الإلكتروني</th>
                    <th class="p-4">الدور</th>
                    <th class="p-4">الحالة</th>
                    <th class="p-4">تاريخ الانضمام</th>
                    <th class="p-4 text-center">إجراءات</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-sm">
                @foreach (var user in Model)
                {
                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="p-4 font-bold text-gray-800">
                            <div class="flex items-center">
                                <img src="https://ui-avatars.com/api/?name=@user.FullName&background=random" class="w-8 h-8 rounded-lg ml-3 border border-gray-100 shadow-sm">
                                <div>
                                    <div>@user.FullName</div>
                                    <div class="flex gap-1 mt-1">
                                        @if(user.IsAdmin){ <span class="bg-red-500 text-white text-[8px] px-1 rounded">ADMIN</span> }
                                        @if(user.IsExecutor){ <span class="bg-blue-500 text-white text-[8px] px-1 rounded">EXEC</span> }
                                        @if(user.IsStaff){ <span class="bg-green-500 text-white text-[8px] px-1 rounded">STAFF</span> }
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td class="p-4 text-gray-600">@user.Email</td>
                        <td class="p-4">
                            <div class="flex flex-wrap gap-1">
                                @foreach(var r in user.Roles)
                                {
                                    <span class="px-2 py-0.5 rounded-full text-[10px] font-bold
                                        @(r.Name == "Admin" ? "bg-purple-100 text-purple-700" : 
                                          r.Name == "Executor" ? "bg-blue-100 text-blue-700" : "bg-orange-100 text-orange-700")">
                                        @r.Name
                                    </span>
                                }
                            </div>
                        </td>
                        <td class="p-4 text-center">
                            @if (user.IsActive)
                            {
                                <span class="bg-green-50 text-green-700 border border-green-200 px-2 py-0.5 rounded text-[10px] font-bold">نشط</span>
                            }
                            else
                            {
                                <span class="bg-red-50 text-red-700 border border-red-200 px-2 py-0.5 rounded text-[10px] font-bold">محظور</span>
                            }
                        </td>
                        <td class="p-4 text-gray-500 text-xs font-medium">@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td class="p-4">
                            <div class="flex justify-center space-x-2 rtl:space-x-reverse">
                                <a asp-action="UserDetails" asp-route-id="@user.Id" class="text-indigo-600 hover:bg-indigo-50 p-2 rounded-lg transition-all" title="عرض الملف">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="EditUser" asp-route-id="@user.Id" class="text-blue-600 hover:bg-blue-50 p-2 rounded-lg transition-all" title="تعديل">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="ToggleUserStatus" asp-route-id="@user.Id" method="post" class="inline">
                                    <button type="submit" class="@(user.IsActive ? "text-orange-500 hover:bg-orange-50" : "text-green-500 hover:bg-green-50") p-2 rounded-lg transition-all" title="@(user.IsActive ? "حظر" : "تفعيل")">
                                        <i class="fas @(user.IsActive ? "fa-user-slash" : "fa-user-check")"></i>
                                    </button>
                                </form>
                                <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="inline" onsubmit="return confirm('هل أنت متأكد من حذف هذا المستخدم نهائياً؟')">
                                    <button type="submit" class="text-red-500 hover:bg-red-50 p-2 rounded-lg transition-all" title="حذف">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
