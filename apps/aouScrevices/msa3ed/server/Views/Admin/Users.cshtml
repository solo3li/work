@model IEnumerable<Uis.Server.Models.User>

@{
    ViewData["Title"] = "إدارة المستخدمين";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-6 border-b border-gray-100 flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <h3 class="text-xl font-bold text-gray-800">قائمة الأعضاء</h3>
        
        <!-- Search & Filter Form -->
        <form method="get" class="flex flex-wrap items-center gap-3 rtl:space-x-reverse">
            <div class="relative">
                <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                <input type="text" name="search" value="@ViewBag.Search" placeholder="بحث بالاسم أو الإيميل..." 
                       class="pl-10 pr-4 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 outline-none min-w-[250px]">
            </div>
            <select name="role" onchange="this.form.submit()" class="px-4 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 outline-none bg-white font-bold">
                <option value="">كل الأدوار</option>
                <option value="Student" selected="@(ViewBag.Role == "Student")">طلاب</option>
                <option value="Executor" selected="@(ViewBag.Role == "Executor")">منفذين</option>
                <option value="Admin" selected="@(ViewBag.Role == "Admin")">مدراء</option>
            </select>
            <button type="submit" class="bg-indigo-600 text-white px-6 py-2 rounded-xl font-bold hover:bg-indigo-700 transition-all shadow-md">تصفية</button>
            @if(!string.IsNullOrEmpty(ViewBag.Search) || !string.IsNullOrEmpty(ViewBag.Role))
            {
                <a href="/Admin/Users" class="text-red-500 text-sm font-bold hover:underline">إلغاء</a>
            }
        </form>
    </div>
    
    <div class="overflow-x-auto">
        <table class="w-full text-right">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100 text-gray-500 font-bold text-xs">
                    <th class="p-4">الاسم الكامل</th>
                    <th class="p-4">البريد الإلكتروني</th>
                    <th class="p-4">الدور</th>
                    <th class="p-4">الحالة</th>
                    <th class="p-4">تاريخ الانضمام</th>
                    <th class="p-4 text-center">إجراءات</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-sm">
                @foreach (var user in Model)
                {
                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="p-4 font-bold text-gray-800">
                            <div class="flex items-center">
                                <img src="https://ui-avatars.com/api/?name=@user.FullName&background=random" class="w-8 h-8 rounded-lg ml-3 border border-gray-100 shadow-sm">
                                @user.FullName
                            </div>
                        </td>
                        <td class="p-4 text-gray-600">@user.Email</td>
                        <td class="p-4">
                            <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase
                                @(user.Role?.Name == "Admin" ? "bg-purple-100 text-purple-700" : 
                                  user.Role?.Name == "Executor" ? "bg-blue-100 text-blue-700" : "bg-orange-100 text-orange-700")">
                                @(user.Role?.Name ?? "غير محدد")
                            </span>
                        </td>
                        <td class="p-4 text-center">
                            @if (user.IsActive)
                            {
                                <span class="bg-green-50 text-green-700 border border-green-200 px-2 py-0.5 rounded text-[10px] font-bold">نشط</span>
                            }
                            else
                            {
                                <span class="bg-red-50 text-red-700 border border-red-200 px-2 py-0.5 rounded text-[10px] font-bold">محظور</span>
                            }
                        </td>
                        <td class="p-4 text-gray-500 text-xs font-medium">@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td class="p-4">
                            <form asp-action="ToggleUserStatus" asp-route-id="@user.Id" method="post" class="flex justify-center">
                                @if (user.IsActive)
                                {
                                    <button type="submit" class="text-red-500 hover:bg-red-50 px-3 py-1.5 rounded-lg transition-all text-xs font-black border border-red-100">
                                        <i class="fas fa-ban ml-1"></i>حظر
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="text-green-600 hover:bg-green-50 px-3 py-1.5 rounded-lg transition-all text-xs font-black border border-green-100">
                                        <i class="fas fa-check ml-1"></i>تفعيل
                                    </button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
