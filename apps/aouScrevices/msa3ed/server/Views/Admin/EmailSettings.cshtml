@model IEnumerable<Uis.Server.Models.SystemSetting>

@{
    ViewData["Title"] = "إعدادات البريد الإلكتروني";
    var success = TempData["Success"] as string;
}

@if (!string.IsNullOrEmpty(success))
{
    <div class="mb-6 p-4 bg-green-50 border border-green-100 text-green-700 rounded-2xl flex items-center animate-fade-in">
        <i class="fas fa-check-circle ml-3"></i>
        <span class="font-bold text-sm">@success</span>
    </div>
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2">
        <form asp-action="UpdateEmailSettings" method="post" class="space-y-8">
            <!-- SMTP Configuration Card -->
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-6 border-b border-gray-50 bg-gray-50/50 flex items-center">
                    <div class="w-10 h-10 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center ml-4">
                        <i class="fas fa-server"></i>
                    </div>
                    <div>
                        <h3 class="text-lg font-black text-gray-800">إعدادات سيرفر SMTP</h3>
                        <p class="text-xs text-gray-400">تحكم في كيفية إرسال النظام للرسائل</p>
                    </div>
                </div>
                
                <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-6">
                    @foreach (var key in new[] { "Email.SmtpServer", "Email.SmtpPort", "Email.SenderName", "Email.SenderEmail", "Email.Password" })
                    {
                        var setting = Model.FirstOrDefault(s => s.Key == key);
                        var isPassword = key.Contains("Password");
                        
                        <div class="@(key == "Email.SmtpServer" ? "md:col-span-1" : "")">
                            <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2">@setting?.Description</label>
                            <input type="@(isPassword ? "password" : "text")" 
                                   name="settings[@key]" 
                                   value="@setting?.Value"
                                   required
                                   class="w-full px-4 py-3 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all bg-gray-50 font-bold text-sm">
                        </div>
                    }
                </div>
            </div>

            <!-- Email Template Card -->
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-6 border-b border-gray-50 bg-gray-50/50 flex items-center">
                    <div class="w-10 h-10 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center ml-4">
                        <i class="fas fa-file-code"></i>
                    </div>
                    <div>
                        <h3 class="text-lg font-black text-gray-800">قالب البريد الرئيسي (HTML)</h3>
                        <p class="text-xs text-gray-400">صمم المظهر العام لرسائل النظام</p>
                    </div>
                </div>
                
                <div class="p-8">
                    @{
                        var template = Model.FirstOrDefault(s => s.Key == "Email.Template.Base");
                    }
                    <div class="mb-4 p-4 bg-amber-50 rounded-2xl border border-amber-100 flex items-start">
                        <i class="fas fa-info-circle text-amber-500 mt-1 ml-3"></i>
                        <p class="text-xs text-amber-800 leading-relaxed font-medium">
                            استخدم الكود <code>{TITLE}</code> و <code>{CONTENT}</code> داخل القالب لتحديد مكان ظهور العنوان والمحتوى المتغير لكل رسالة.
                        </p>
                    </div>
                    
                    <textarea name="settings[Email.Template.Base]" 
                              rows="15" 
                              class="w-full px-6 py-4 border border-gray-200 rounded-3xl focus:ring-2 focus:ring-purple-500 outline-none transition-all bg-gray-900 text-green-400 font-mono text-xs leading-relaxed"
                              spellcheck="false">@template?.Value</textarea>
                </div>
            </div>

            <div class="flex space-x-4 rtl:space-x-reverse">
                <button type="submit" class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-black py-4 rounded-2xl transition-all shadow-xl shadow-indigo-100 hover:scale-[1.01] active:scale-95">
                    <i class="fas fa-save ml-2"></i>حفظ كافة التغييرات
                </button>
            </div>
        </form>
    </div>

    <!-- Instructions / Tips -->
    <div class="lg:col-span-1 space-y-6">
        <div class="bg-indigo-900 rounded-3xl p-8 text-white shadow-xl relative overflow-hidden">
            <i class="fas fa-lightbulb absolute -right-4 -bottom-4 text-9xl text-white/5 -rotate-12"></i>
            <h4 class="text-lg font-black mb-4 flex items-center relative z-10">
                <i class="fas fa-magic ml-2 text-indigo-300"></i> نصائح احترافية
            </h4>
            <ul class="space-y-4 relative z-10">
                <li class="flex items-start">
                    <span class="w-5 h-5 bg-white/20 rounded-full flex items-center justify-center shrink-0 ml-3 text-[10px] font-black">1</span>
                    <p class="text-xs text-indigo-100 leading-relaxed">استخدم Gmail App Passwords إذا كنت تستخدم سيرفر Gmail لتجنب مشاكل الدخول.</p>
                </li>
                <li class="flex items-start">
                    <span class="w-5 h-5 bg-white/20 rounded-full flex items-center justify-center shrink-0 ml-3 text-[10px] font-black">2</span>
                    <p class="text-xs text-indigo-100 leading-relaxed">تأكد من أن كود الـ HTML الخاص بك متجاوب (Responsive) ليعمل جيداً على هواتف الطلاب.</p>
                </li>
                <li class="flex items-start">
                    <span class="w-5 h-5 bg-white/20 rounded-full flex items-center justify-center shrink-0 ml-3 text-[10px] font-black">3</span>
                    <p class="text-xs text-indigo-100 leading-relaxed">يمكنك دائماً العودة للقالب الأصلي عبر حذف المحتوى في المحرر وحفظه (سيقوم النظام باسترجاع الافتراضي عند الحاجة).</p>
                </li>
            </ul>
        </div>

        <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100">
            <h4 class="text-sm font-black text-gray-800 mb-6 flex items-center">
                <i class="fas fa-history ml-2 text-gray-400"></i> اختبر الإعدادات
            </h4>
            <p class="text-xs text-gray-500 mb-6">احفظ التغييرات أولاً، ثم قم بمحاولة تسجيل الدخول من التطبيق لتصلك رسالة الـ OTP الجديدة.</p>
            <button class="w-full py-3 bg-gray-50 text-gray-400 border-2 border-dashed border-gray-200 rounded-2xl text-xs font-bold cursor-not-allowed">
                إرسال بريد تجريبي (قريباً)
            </button>
        </div>
    </div>
</div>

<style>
    .animate-fade-in { animation: fadeIn 0.5s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
</style>
