@model IEnumerable<Uis.Server.Models.Service>

@{
    ViewData["Title"] = "إدارة الخدمات";
}

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-6 border-b border-gray-100 flex justify-between items-center">
        <h3 class="text-lg font-bold text-gray-800">الخدمات المتاحة في المنصة</h3>
        <button class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg font-medium transition-colors shadow-sm">
            <i class="fas fa-plus ml-2"></i>إضافة خدمة
        </button>
    </div>
    
    <div class="overflow-x-auto">
        <table class="w-full text-right">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100 text-gray-500 font-semibold text-sm">
                    <th class="p-4">عنوان الخدمة</th>
                    <th class="p-4">التصنيف</th>
                    <th class="p-4">السعر الأساسي</th>
                    <th class="p-4">الحالة</th>
                    <th class="p-4">إجراءات</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-sm">
                @foreach (var srv in Model)
                {
                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="p-4 font-medium text-gray-800 max-w-xs truncate" title="@srv.Title">@srv.Title</td>
                        <td class="p-4">
                            <span class="bg-gray-100 text-gray-600 px-2 py-1 rounded text-xs font-medium border border-gray-200">
                                @(srv.Category?.Name ?? "غير مصنف")
                            </span>
                        </td>
                        <td class="p-4 font-bold text-indigo-600">@srv.BasePrice.ToString("C")</td>
                        <td class="p-4">
                            @if (srv.IsActive)
                            {
                                <span class="bg-green-50 text-green-600 px-2 py-1 rounded text-xs font-bold border border-green-100">مفعل</span>
                            }
                            else
                            {
                                <span class="bg-red-50 text-red-600 px-2 py-1 rounded text-xs font-bold border border-red-100">موقوف</span>
                            }
                        </td>
                        <td class="p-4">
                            <div class="flex space-x-2 rtl:space-x-reverse">
                                <button class="text-blue-500 hover:text-blue-700 p-1" title="تعديل"><i class="fas fa-edit"></i></button>
                                <button class="text-red-500 hover:text-red-700 p-1" title="حذف"><i class="fas fa-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
