@model Uis.Server.Models.Role
@{
    ViewData["Title"] = "تعديل الدور";
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="p-8 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
            <h3 class="text-xl font-black text-gray-800">تعديل الدور: @Model.Name</h3>
            @if(Model.IsSystemRole)
            {
                <span class="bg-amber-100 text-amber-700 text-[10px] font-bold px-3 py-1 rounded-full border border-amber-200">دور نظامي</span>
            }
        </div>
        
        <form asp-action="EditRole" asp-route-id="@Model.Id" method="post" class="p-8 space-y-6">
            <input type="hidden" asp-for="Id">
            
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">اسم الدور</label>
                <input type="text" name="name" value="@Model.Name" @(Model.IsSystemRole ? "readonly" : "") required 
                       class="w-full px-4 py-3 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all @(Model.IsSystemRole ? "bg-gray-100 text-gray-500 cursor-not-allowed" : "bg-gray-50 font-bold")">
                @if(Model.IsSystemRole)
                {
                    <p class="mt-2 text-[10px] text-amber-600 font-medium">لا يمكن تغيير اسم أدوار النظام الأساسية لضمان استقرار التطبيق.</p>
                }
            </div>

            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">الوصف</label>
                <textarea name="description" rows="4" required
                          class="w-full px-4 py-3 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all bg-gray-50 text-sm">@Model.Description</textarea>
            </div>

            <div class="flex justify-end gap-3 pt-4">
                <a asp-action="Roles" class="px-8 py-3 border border-gray-200 rounded-2xl font-bold text-gray-600 hover:bg-gray-50 transition-all">إلغاء</a>
                <button type="submit" class="px-10 py-3 bg-indigo-600 text-white rounded-2xl font-black hover:bg-indigo-700 transition-all shadow-lg hover:scale-[1.02] active:scale-95">
                    <i class="fas fa-save ml-2"></i>حفظ التغييرات
                </button>
            </div>
        </form>
    </div>
</div>
