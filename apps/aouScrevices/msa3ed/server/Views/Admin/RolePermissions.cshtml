@model Uis.Server.Models.Role

@{
    ViewData["Title"] = $"تعديل صلاحيات دور - {Model.Name}";
    var allPermissions = ViewBag.AllPermissions as IEnumerable<Uis.Server.Models.Permission>;
    var currentPermissionIds = Model.RolePermissions.Select(rp => rp.PermissionId).ToList();
}

<div class="mb-6">
    <a href="/Admin/Roles" class="text-indigo-600 hover:text-indigo-800 font-bold flex items-center transition-all">
        <i class="fas fa-arrow-right ml-2"></i> العودة للأدوار
    </a>
</div>

<div class="max-w-4xl mx-auto">
    <form asp-action="UpdateRolePermissions" method="post">
        <input type="hidden" name="roleId" value="@Model.Id" />
        
        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden mb-8">
            <div class="bg-indigo-600 p-8 text-white flex justify-between items-center">
                <div>
                    <h2 class="text-2xl font-black">إدارة صلاحيات @Model.Name</h2>
                    <p class="text-indigo-100 text-sm mt-1">حدد الوظائف التي يسمح لهذا الدور بالوصول إليها.</p>
                </div>
                <div class="w-16 h-16 bg-white/10 rounded-2xl flex items-center justify-center border border-white/20">
                    <i class="fas fa-user-shield text-3xl text-white"></i>
                </div>
            </div>

            <div class="p-8">
                @foreach (var group in allPermissions.GroupBy(p => p.Group))
                {
                    <div class="mb-10">
                        <h3 class="text-sm font-black text-indigo-900 uppercase tracking-widest mb-6 pb-2 border-b-2 border-indigo-50 flex items-center">
                            <span class="w-2 h-2 bg-indigo-500 rounded-full ml-3"></span>
                            المجموعة: @(group.Key ?? "عام")
                        </h3>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            @foreach (var p in group)
                            {
                                <label class="flex items-start p-4 rounded-2xl border-2 transition-all cursor-pointer group
                                    @(currentPermissionIds.Contains(p.Id) ? "border-indigo-500 bg-indigo-50/30" : "border-gray-50 bg-gray-50/30 hover:border-indigo-200")">
                                    <div class="flex items-center h-5">
                                        <input type="checkbox" name="permissionIds" value="@p.Id" 
                                               class="w-5 h-5 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500"
                                               @(currentPermissionIds.Contains(p.Id) ? "checked" : "")>
                                    </div>
                                    <div class="mr-4">
                                        <p class="text-sm font-bold text-gray-800 group-hover:text-indigo-600 transition-colors">@p.Name</p>
                                        <p class="text-[10px] text-gray-400 mt-1 font-medium leading-relaxed">@p.Description</p>
                                    </div>
                                </label>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="p-8 bg-gray-50 border-t border-gray-100 flex space-x-4 rtl:space-x-reverse">
                <button type="submit" class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-black py-4 rounded-2xl transition-all shadow-lg hover:scale-[1.01] active:scale-95">
                    <i class="fas fa-save ml-2"></i>حفظ وتطبيق الصلاحيات
                </button>
                <a href="/Admin/Roles" class="px-10 bg-white text-gray-500 font-bold py-4 rounded-2xl border border-gray-200 hover:bg-gray-100 transition-all">إلغاء</a>
            </div>
        </div>
    </form>
</div>
