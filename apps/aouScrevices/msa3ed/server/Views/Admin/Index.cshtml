@{
    ViewData["Title"] = "الرئيسية";
    var stats = ViewBag.Stats;
    var recentOrders = ViewBag.RecentOrders as IEnumerable<Uis.Server.Models.Order>;
}

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
    <a href="/Admin/Users" class="group bg-white rounded-2xl shadow-sm border border-gray-100 p-6 flex flex-col justify-between hover:border-indigo-500 hover:shadow-indigo-100 transition-all duration-300">
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 group-hover:text-indigo-500 transition-colors">إجمالي المستخدمين</p>
        <div class="flex items-center justify-between">
            <h3 class="text-3xl font-black text-gray-800">@stats?.TotalUsers</h3>
            <div class="w-10 h-10 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center group-hover:bg-indigo-600 group-hover:text-white transition-all"><i class="fas fa-users"></i></div>
        </div>
    </a>
    
    <a href="/Admin/Orders" class="group bg-white rounded-2xl shadow-sm border border-gray-100 p-6 flex flex-col justify-between hover:border-green-500 hover:shadow-green-100 transition-all duration-300">
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 group-hover:text-green-500 transition-colors">إجمالي الطلبات</p>
        <div class="flex items-center justify-between">
            <h3 class="text-3xl font-black text-gray-800">@stats?.TotalOrders</h3>
            <div class="w-10 h-10 bg-green-50 text-green-600 rounded-xl flex items-center justify-center group-hover:bg-green-600 group-hover:text-white transition-all"><i class="fas fa-shopping-cart"></i></div>
        </div>
    </a>

    <a href="/Admin/Kyc" class="group bg-white rounded-2xl shadow-sm border border-gray-100 p-6 flex flex-col justify-between hover:border-yellow-500 hover:shadow-yellow-100 transition-all duration-300">
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 group-hover:text-yellow-600 transition-colors">KYC معلق</p>
        <div class="flex items-center justify-between">
            <h3 class="text-3xl font-black text-gray-800">@stats?.PendingKyc</h3>
            <div class="w-10 h-10 bg-yellow-50 text-yellow-600 rounded-xl flex items-center justify-center group-hover:bg-yellow-600 group-hover:text-white transition-all"><i class="fas fa-id-card"></i></div>
        </div>
    </a>

    <a href="/Admin/Tickets" class="group bg-white rounded-2xl shadow-sm border border-gray-100 p-6 flex flex-col justify-between hover:border-red-500 hover:shadow-red-100 transition-all duration-300">
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 group-hover:text-red-500 transition-colors">تذاكر مفتوحة</p>
        <div class="flex items-center justify-between">
            <h3 class="text-3xl font-black text-gray-800">@stats?.OpenTickets</h3>
            <div class="w-10 h-10 bg-red-50 text-red-600 rounded-xl flex items-center justify-center group-hover:bg-red-600 group-hover:text-white transition-all"><i class="fas fa-headset"></i></div>
        </div>
    </a>

    <a href="/Admin/Payments" class="group bg-white rounded-2xl shadow-sm border border-gray-100 p-6 flex flex-col justify-between hover:border-indigo-500 hover:shadow-indigo-100 transition-all duration-300">
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 group-hover:text-indigo-600 transition-colors">إجمالي الإيرادات</p>
        <div class="flex items-center justify-between">
            <h3 class="text-2xl font-black text-indigo-700">@stats?.TotalRevenue.ToString("N0")</h3>
            <div class="w-10 h-10 bg-indigo-100 text-indigo-800 rounded-xl flex items-center justify-center font-bold text-xs group-hover:bg-indigo-700 group-hover:text-white transition-all">ج.م</div>
        </div>
    </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
        <div class="flex justify-between items-center mb-8">
            <h3 class="text-xl font-black text-gray-800 flex items-center"><i class="fas fa-chart-line ml-3 text-indigo-500"></i> نشاط الطلبات</h3>
            <span class="text-[10px] text-indigo-600 font-black bg-indigo-50 px-3 py-1 rounded-full uppercase tracking-tighter">Live Monitor</span>
        </div>
        <canvas id="ordersChart" height="130"></canvas>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 overflow-hidden relative">
        <h3 class="text-lg font-black text-gray-800 mb-8 border-b border-gray-50 pb-4">آخر الطلبات</h3>
        <div class="space-y-4">
            @foreach(var order in recentOrders)
            {
                <a asp-action="OrderDetails" asp-route-id="@order.Id" class="flex items-center p-3 hover:bg-indigo-50 rounded-2xl transition-all border border-transparent hover:border-indigo-100 group">
                    <div class="w-10 h-10 rounded-xl bg-gray-100 flex items-center justify-center text-gray-400 group-hover:bg-white group-hover:text-indigo-600 shadow-sm transition-all"><i class="fas fa-box-open"></i></div>
                    <div class="mr-3 flex-1 overflow-hidden">
                        <h4 class="text-xs font-black text-gray-800 truncate">@order.Service.Title</h4>
                        <p class="text-[9px] text-gray-400 mt-0.5">@order.Student.FullName • @order.CreatedAt.ToString("HH:mm")</p>
                    </div>
                    <span class="text-xs font-black text-indigo-600 mr-2">@order.Price.ToString("N0")</span>
                </a>
            }
            <a href="/Admin/Orders" class="block text-center text-indigo-600 text-xs font-black mt-6 hover:bg-indigo-50 py-3 rounded-xl border border-dashed border-indigo-200 transition-all">مشاهدة جميع الطلبات</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        fetch('/Admin/GetDashboardStats')
            .then(res => res.json())
            .then(data => {
                const ctx = document.getElementById('ordersChart').getContext('2d');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: data.labels,
                        datasets: [{
                            label: 'الطلبات اليومية',
                            data: data.data,
                            borderColor: '#6366F1',
                            backgroundColor: 'rgba(99, 102, 241, 0.05)',
                            fill: true,
                            tension: 0.5,
                            borderWidth: 4,
                            pointRadius: 6,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: '#6366F1',
                            pointBorderWidth: 3
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { display: false },
                            x: { grid: { display: false }, ticks: { font: { family: 'Tajawal', size: 10, weight: 'bold' } } }
                        }
                    }
                });
            });
    </script>
}
