<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - لوحة تحكم UIS</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS (via CDN for simplicity in MVP) -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Tajawal', 'sans-serif'] },
                    colors: { primary: '#6366F1', secondary: '#A855F7', dark: '#1E293B', light: '#F8FAFC' }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Tajawal', sans-serif; background-color: #F8FAFC; }
        .sidebar { min-height: 100vh; }
        .nav-link.active { background-color: rgba(255, 255, 255, 0.1); border-right: 4px solid #fff; }
        .nav-link:hover { background-color: rgba(255, 255, 255, 0.05); }
    </style>
</head>
<body class="text-gray-800 antialiased flex h-screen overflow-hidden">
    
    <!-- Sidebar -->
    <aside class="w-64 bg-indigo-600 text-white flex flex-col shadow-xl sidebar">
        <div class="p-6 text-center border-b border-indigo-500/50">
            <h1 class="text-3xl font-extrabold tracking-wider">UIS<span class="text-indigo-200">Admin</span></h1>
            <p class="text-indigo-200 text-sm mt-1">لوحة تحكم النظام</p>
        </div>
        <nav class="flex-1 px-2 py-4 space-y-2 overflow-y-auto">
            <a href="/Admin" class="nav-link flex items-center px-4 py-3 text-white rounded-lg transition-colors @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <i class="fas fa-home w-6 text-center"></i>
                <span class="mx-3 font-semibold">الرئيسية</span>
            </a>
            <a href="/Admin/Users" class="nav-link flex items-center px-4 py-3 text-white rounded-lg transition-colors @(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")">
                <i class="fas fa-users w-6 text-center"></i>
                <span class="mx-3 font-semibold">المستخدمين</span>
            </a>
            <a href="/Admin/Kyc" class="nav-link flex items-center px-4 py-3 text-white rounded-lg transition-colors @(ViewContext.RouteData.Values["action"]?.ToString() == "Kyc" ? "active" : "")">
                <i class="fas fa-id-card w-6 text-center"></i>
                <span class="mx-3 font-semibold">طلبات KYC</span>
            </a>
            <a href="/Admin/Services" class="nav-link flex items-center px-4 py-3 text-white rounded-lg transition-colors @(ViewContext.RouteData.Values["action"]?.ToString() == "Services" ? "active" : "")">
                <i class="fas fa-briefcase w-6 text-center"></i>
                <span class="mx-3 font-semibold">الخدمات</span>
            </a>
            <a href="/Admin/Orders" class="nav-link flex items-center px-4 py-3 text-white rounded-lg transition-colors @(ViewContext.RouteData.Values["action"]?.ToString() == "Orders" ? "active" : "")">
                <i class="fas fa-shopping-cart w-6 text-center"></i>
                <span class="mx-3 font-semibold">الطلبات</span>
            </a>
            <a href="/Admin/Tickets" class="nav-link flex items-center px-4 py-3 text-white rounded-lg transition-colors @(ViewContext.RouteData.Values["action"]?.ToString() == "Tickets" ? "active" : "")">
                <i class="fas fa-headset w-6 text-center"></i>
                <span class="mx-3 font-semibold">الدعم الفني</span>
            </a>
        </nav>
        <div class="p-4 border-t border-indigo-500/50">
            <a href="#" class="flex items-center px-4 py-2 text-indigo-100 hover:text-white transition-colors">
                <i class="fas fa-sign-out-alt w-6 text-center"></i>
                <span class="mx-3">تسجيل الخروج</span>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col h-screen overflow-hidden bg-gray-50">
        <!-- Top Header -->
        <header class="flex items-center justify-between px-6 py-4 bg-white border-b border-gray-200">
            <div class="flex items-center">
                <button class="text-gray-500 focus:outline-none lg:hidden">
                    <i class="fas fa-bars text-xl"></i>
                </button>
                <h2 class="text-2xl font-bold text-gray-800 ml-4">@ViewData["Title"]</h2>
            </div>
            <div class="flex items-center space-x-4 rtl:space-x-reverse">
                <button class="flex items-center text-gray-500 hover:text-indigo-600 focus:outline-none relative">
                    <i class="fas fa-bell text-xl"></i>
                    <span class="absolute top-0 right-0 -mt-1 -mr-1 flex h-3 w-3">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-pink-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-3 w-3 bg-pink-500"></span>
                    </span>
                </button>
                <div class="flex items-center">
                    <img class="w-10 h-10 rounded-full border-2 border-indigo-200" src="https://ui-avatars.com/api/?name=Admin&background=6366F1&color=fff" alt="Admin Avatar">
                    <span class="mx-2 font-medium text-gray-700">مدير النظام</span>
                </div>
            </div>
        </header>

        <!-- Content Area -->
        <div class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-50 p-6">
            @RenderBody()
        </div>
    </main>

    @RenderSection("Scripts", required: false)
</body>
</html>
